# SonarQube 项目配置示例
# 将此文件复制到项目根目录，命名为 sonar-project.properties

# ==================== 基本信息 ====================
# 项目唯一标识（必需）
sonar.projectKey=acrn_rtos

# 项目显示名称
sonar.projectName=ACRN_RTOS

# 项目版本
sonar.projectVersion=1.0

# ==================== 源代码配置 ====================
# 源代码目录（相对于项目根目录）
# 多个目录用逗号分隔
sonar.sources=common,examples,third_part/Ec_Master_Lib

# 包含的文件类型
# 只扫描 C/C++ 源文件和头文件
sonar.inclusions=**/*.c,**/*.cpp,**/*.h,**/*.hpp

# 排除的目录/文件
# 通常排除构建目录、第三方库等
sonar.exclusions=**/build/**,**/bin/**,**/test/**,**/.cache/**,**/.git/**

# ==================== 编码设置 ====================
sonar.sourceEncoding=UTF-8

# ==================== 服务器配置 ====================
# SonarQube 服务器地址
# 注意: 在 Docker 容器内运行扫描时，使用宿主机 IP
sonar.host.url=http://172.22.158.95:9000

# ==================== CXX 插件配置 ====================
# C/C++ 文件后缀
sonar.cxx.file.suffixes=.cxx,.cpp,.cc,.c,.hxx,.hpp,.hh,.h

# 启用错误恢复（容错模式）
sonar.cxx.errorRecoveryEnabled=true

# ==================== 可选配置 ====================
# 测试文件目录（如果有）
# sonar.tests=test

# 编译数据库（compile_commands.json）
# 可以提供更准确的分析结果
# sonar.cxx.compileCommands=build/compile_commands.json

# 包含目录（头文件搜索路径）
# sonar.cxx.includeDirectories=./include,./common/include

# 预定义宏
# sonar.cxx.defines=DEBUG=1,VERSION=1.0

# 覆盖率报告（如果有）
# sonar.coverageReportPaths=coverage/lcov.info
